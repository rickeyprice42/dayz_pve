# =========================
# 🎮 DayZ Server Ignore
# =========================

# ❌ Основные игровые файлы
addons/
dta/
bliss/
mpmissions/*.pbo

# ❌ Логи и профили
profiles/
*.log
*.rpt
*.mdmp

# ❌ Кэш и временные файлы
*.tmp
*.bak
*.cache

# ❌ Ключи (генерируются автоматически)
keys/

# ❌ ВСЕ моды (КРИТИЧНО)
@*/

# ❌ Steam Workshop (если вдруг окажется внутри проекта)
steamapps/

# ❌ OS мусор
.DS_Store
Thumbs.db

# ❌ VS Code (локальные настройки)
.vscode/

# ❌ Node / прочее (на будущее, если сайт рядом)
node_modules/

# ❌ Архивы
*.zip
*.rar
*.7z